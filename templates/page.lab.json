        "text_NmMfCd": {
          "type": "text",
          "settings": {
            "text": "<p>At Jander, formulation always comes first.<br/><br/>We select each active ingredient based on proven scientific evidence and incorporate it at effective concentrations to deliver visible, measurable results. But efficacy is never about individual ingredients alone - it’s about how they work together.<br/><br/>Our formulas are designed as intelligent systems, where every component supports and enhances the performance of the next. The result is products that work harder, smarter and more efficiently.<br/><br/>Combining clinically recognized actives with advanced cosmetic technologies, our formulations target hydration, barrier support, firmness, inflammation and the visible signs of ageing with precision and purpose.</p>",
            "text_style": "subtitle",
            "text__color": ""
          }
        }
